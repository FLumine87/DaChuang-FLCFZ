# ============================================================
# 环境变量示例 - 复制为 .env.local 后按实际情况填写
# ============================================================

# 后端 API 基础地址
# - 开发环境留空，配合 vite.config.ts 里的 /api 代理使用
# - 生产环境填写实际后端地址，例如 https://api.your-domain.com
VITE_API_BASE_URL=

# 是否使用 Mock 数据
# - true:  所有 API 调用返回本地 mock 数据（脱离后端，用于演示/离线开发）
# - false: 所有 API 调用走真实后端
VITE_USE_MOCK=true

# 开发环境后端地址（仅供 vite.config.ts 代理使用）
# 若后端本地运行在其他端口/主机，修改此项
VITE_DEV_PROXY_TARGET=http://localhost:8000
